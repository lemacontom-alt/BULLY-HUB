function CreateDarkSlider_Mov(parent, text, min, max, defaultVal, isDecimal, callback)
    local sFrame = Instance.new("Frame", parent)
    sFrame.Size = UDim2.new(1, -16, 0, 45)
    sFrame.BackgroundTransparency = 1
    
    local val = math.clamp(defaultVal, min, max)
    
    local sTitle = Instance.new("TextLabel", sFrame)
    sTitle.Size = UDim2.new(1, 0, 0, 16)
    sTitle.Text = text .. ": " .. (isDecimal and string.format("%.2f", val) or tostring(math.floor(val)))
    sTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    sTitle.TextStrokeTransparency = 0
    sTitle.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    sTitle.Font = Enum.Font.GothamBlack
    sTitle.TextSize = 13
    sTitle.TextXAlignment = Enum.TextXAlignment.Left
    sTitle.BackgroundTransparency = 1

    local sBg = Instance.new("Frame", sFrame)
    sBg.Size = UDim2.new(1, 0, 0, 8)
    sBg.Position = UDim2.new(0, 0, 0, 26)
    sBg.BackgroundColor3 = Theme.Volcanic
    Instance.new("UICorner", sBg).CornerRadius = UDim.new(1, 0)
    
    local pct = (val - min) / (max - min)
    local sFill = Instance.new("Frame", sBg)
    sFill.Size = UDim2.new(pct, 0, 1, 0)
    sFill.BackgroundColor3 = Theme.AmberMain
    Instance.new("UICorner", sFill).CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("Frame", sBg)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(pct, -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    
    local knobStroke = Instance.new("UIStroke", knob)
    knobStroke.Color = Color3.fromRGB(0, 0, 0)
    knobStroke.Thickness = 1.5

    local sBtn = Instance.new("TextButton", sBg)
    sBtn.Size = UDim2.new(1, 0, 1, 0)
    sBtn.BackgroundTransparency = 1
    sBtn.Text = ""

    local dragging = false
    local moveConnection = nil

    local function updateSlider()
        local mousePos = game:GetService("UserInputService"):GetMouseLocation()
        local percent = math.clamp((mousePos.X - sBg.AbsolutePosition.X) / sBg.AbsoluteSize.X, 0, 1)
        
        sFill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -8, 0.5, -8)
        
        local newVal = min + ((max - min) * percent)
        if not isDecimal then newVal = math.floor(newVal) end
        
        sTitle.Text = text .. ": " .. (isDecimal and string.format("%.2f", newVal) or tostring(newVal))
        if callback then callback(newVal) end
    end

    sBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider()
            if moveConnection then moveConnection:Disconnect() end
            moveConnection = game:GetService("UserInputService").InputChanged:Connect(function(moveInput)
                if moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch then
                    updateSlider()
                end
            end)
        end
    end)
    
    game:GetService("UserInputService").InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                if moveConnection then moveConnection:Disconnect(); moveConnection = nil end
            end
        end
    end)
end

